<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resultado do Formulário | Regimath</title>
    <link rel="stylesheet" href="/css/ver_resultado.css">
    <style>
        .options .correct { background-color: #90ee90; }
        .options .incorrect { background-color: #f08080; }
        .options .correct::after { content: ' ✔'; }
        .options .incorrect::after { content: ' ✘'; }
        .marked-label { float: right; font-size: 0.85rem; font-weight: 700; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Resultado do Formulário: <%= atividade.title %></h1>

        <div class="summary">
            <p><strong>Pontuação:</strong> <%= Number(tentativa.pontuacao_total).toFixed(0) %>%</p>
            <p><strong>Questões Corretas:</strong> <%= respostas.filter(r => r.acertou).length %> de <%= tentativa.total_questoes %></p>
        </div>

        <div class="questions-container">
            <% atividade.questions.forEach((question, index) => { %>
                <% const respostaDoUsuario = respostas[index] || {}; %>
                <div class="question-card">
                    <h2>Questão <%= index + 1 %>: <%= question.text || question.title %></h2>
                    <% if (question.options) { %>
                        <ul class="options">
                            <%
                            const opcoes = Array.isArray(question.options)
                                ? question.options.map((value, i) => [String.fromCharCode(65 + i), value])
                                : Object.entries(question.options).filter(([, value]) => value);
                            const marcada = String(respostaDoUsuario.resposta_marcada || '');
                            const correta = String(question.correct || respostaDoUsuario.resposta || '');
                            opcoes.forEach(([key, value]) => {
                                let className = '';
                                const isSelected = key.toLowerCase() === marcada.toLowerCase();
                                const isCorrect = key.toLowerCase() === correta.toLowerCase();
                                if (isSelected) className = respostaDoUsuario.acertou ? 'correct selected' : 'incorrect selected';
                                else if (isCorrect) className = 'correct';
                            %>
                                <li class="<%= className %>">
                                    <strong><%= key %>)</strong> <%= value %>
                                    <% if (isSelected) { %><span class="marked-label">Sua resposta</span><% } %>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p><strong>Sua resposta:</strong> <%= respostaDoUsuario.resposta_marcada || 'Não respondida' %></p>
                        <p class="<%= respostaDoUsuario.acertou ? 'correct' : 'incorrect' %>">
                            <%= respostaDoUsuario.acertou ? 'Resposta correta' : 'Resposta incorreta' %>
                        </p>
                        <% if (!respostaDoUsuario.acertou) { %>
                            <p><strong>Resposta esperada:</strong> <%= question.correctAnswer || respostaDoUsuario.resposta %></p>
                        <% } %>
                    <% } %>
                </div>
            <% }); %>
        </div>



        <% const recs = recomendacoesProfessores || { focos: [], recomendacoes: [] }; %>
        <section class="teacher-recommendations">
            <div class="recommendation-header">
                <span class="badge">Recomendação inteligente</span>
                <h2>Professores indicados para o seu próximo passo</h2>
                <p>Usamos os pontos de atenção do seu resultado para priorizar professores com maior aderência ao reforço que você precisa.</p>
            </div>

            <% if (recs.focos && recs.focos.length > 0) { %>
                <div class="focus-list" aria-label="Focos identificados no resultado">
                    <% recs.focos.forEach(foco => { %>
                        <span class="focus-chip"><%= foco.descricao %> • <%= Number(foco.percentual).toFixed(0) %>%</span>
                    <% }); %>
                </div>
            <% } %>

            <% if (recs.recomendacoes && recs.recomendacoes.length > 0) { %>
                <div class="recommendation-grid">
                    <% recs.recomendacoes.forEach(professor => { %>
                        <article class="teacher-card">
                            <img src="<%= professor.foto || '/imagens/imagem_perfil.jpg' %>" alt="Foto de <%= professor.nome %>">
                            <div>
                                <h3><%= professor.nome %></h3>
                                <p class="match-score"><%= professor.score %>% de aderência estimada</p>
                                <p class="teacher-disciplines"><%= professor.disciplinas && professor.disciplinas.length ? professor.disciplinas.join(', ') : 'Matemática' %></p>
                                <ul>
                                    <% professor.motivos.slice(0, 2).forEach(motivo => { %>
                                        <li><%= motivo %></li>
                                    <% }); %>
                                </ul>
                                <a href="/exibir_prof/<%= professor.id %>" class="recommendation-button">Ver professor</a>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="empty-recommendations">Ainda não há professores disponíveis para recomendação automática.</p>
            <% } %>
        </section>

        <a href="/historico_formularios" class="back-button">Voltar ao Histórico</a>
    </div>
</body>
</html>