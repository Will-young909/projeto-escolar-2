<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Painel Administrativo | Regimath</title>

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="icon" href="/imagens/Regimath_sem fundo cor preto2.png" />

  <!-- Estilos -->
  <link rel="stylesheet" href="/css/painel_adm.css">
</head>

<body>
  <!-- Header -->
  <header>
    <a href="/" class="logo-link" aria-label="Página inicial Regimath">
      <img src="/imagens/RM_bordo.png" alt="Logo Regimath" class="logo">
    </a>
    <button id="menu-btn" class="menu-btn" aria-label="Abrir menu">☰</button>
  </header>

  <!-- Overlay (para mobile) -->
  <section id="overlay"></section>

  <!-- Menu lateral -->
  <nav id="menu" aria-label="Menu lateral administrativo">
    <button id="close-menu" aria-label="Fechar menu">&times;</button>
    <button id="toggle-menu" aria-label="Recolher menu">
      <svg id="toggle-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="white">
        <path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
      </svg>
    </button>

    <ul class="nav-links">
      <li><a href="#page-dashboard" class="admin-nav-link active"><i class="fa-solid fa-chart-pie"></i><p class="label">Dashboard</p></a></li>
      <li><a href="#page-users" class="admin-nav-link"><i class="fa-solid fa-users"></i><p class="label">Usuários</p><p class="badge" id="pending-teachers-badge"><%= pagination.totalItems %></p></a></li>
      <li><a href="#page-finance" class="admin-nav-link"><i class="fa-solid fa-wallet"></i><p class="label">Financeiro</p></a></li>
      <li><a href="#page-moderation" class="admin-nav-link"><i class="fa-solid fa-shield-halved"></i><p class="label">Moderação</p><p class="badge" id="open-reports-badge"><%= typeof openReports !== 'undefined' ? openReports : 0 %></p></a></li>
      <li><a href="#page-settings" class="admin-nav-link"><i class="fa-solid fa-gear"></i><p class="label">Configurações</p></a></li>
      <li><a href="/" class="admin-nav-link"><i class="fas fa-home"></i><p class="label">Home</p></a></li>
      <li><a href="/logout" class="admin-nav-link"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#fff"><path d="M216-144q-29.7 0-50.85-21.15Q144-186.3 144-216v-528q0-29.7 21.15-50.85Q186.3-816 216-816h264v72H216v528h264v72H216Zm432-168-51-51 81-81H384v-72h294l-81-81 51-51 168 168-168 168Z"/></svg><p class="label">Sair</p></a></li>
    </ul>
  </nav>

  <!-- Conteúdo principal -->
  <main>
    <section class="admin-header-content">
      <h1 id="page-title">Dashboard</h1>
      <section class="admin-profile">
        <i class="fa-solid fa-user-shield"></i> Olá, <strong>Admin</strong>
      </section>
    </section>

    <!-- DASHBOARD -->
    <section class="content-page active" id="page-dashboard">
      <section class="kpi-grid">
        <section class="kpi-card success">
          <section class="kpi-label">Receita da Plataforma (Mês)</section>
          <section id="kpi-revenue" class="kpi-value">Carregando...</section>
        </section>
        <section class="kpi-card warning">
          <section class="kpi-label">Repasse Pendente (Professores)</section>
          <section id="kpi-pending-payments" class="kpi-value">Carregando...</section>
        </section>
        <section class="kpi-card">
          <section class="kpi-label">Novos Alunos (Mês)</section>
          <section id="kpi-new-students" class="kpi-value">Carregando...</section>
        </section>
        <section class="kpi-card">
          <section class="kpi-label">Aulas Concluídas (Mês)</section>
          <section id="kpi-completed-classes" class="kpi-value">Carregando...</section>
        </section>
         <section class="kpi-card">
          <section class="kpi-label">Denúncias Abertas</section>
          <section id="kpi-open-reports" class="kpi-value">Carregando...</section>
        </section>
      </section>

      <section class="card" style="margin-top: 30px;">
        <h2 class="section-title">Atividade Recente</h2>
        <ul style="list-style: none; padding-left: 10px;" id="recent-activity-list">
          <li><i class="fa-solid fa-user-plus" style="color: var(--color-success);"></i> <strong>Novo Professor:</strong> Carlos Mendes aguarda aprovação.</li>
          <li><i class="fa-solid fa-file-invoice-dollar" style="color: var(--color-primary);"></i> <strong>Nova Aula:</strong> Mariana Silva pagou R$ 60,00 para Prof. Ana Beatriz.</li>
          <li><i class="fa-solid fa-flag" style="color: var(--color-error);"></i> <strong>Nova Denúncia:</strong> Aluno X denunciou Professor Y por "Não compareceu".</li>
        </ul>
      </section>
    </section>

    <!-- USUÁRIOS -->
    <section class="content-page" id="page-users">
        
        <section class="card">
            <h2 class="section-title">Professores Aguardando Aprovação (<%= pagination.totalItems %>)</h2>
            
            <form action="/admin/dashboard" method="GET" class="filter-form">
                <input type="hidden" name="status" value="pending">
                <input type="search" name="search" placeholder="Buscar por nome ou email..." value="<%= pagination.search || '' %>">
                <button type="submit" class="btn btn-primary" onclick="window.location.hash = '#page-users';">Filtrar</button>
            </form>

            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Registrado em</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(pendingTeachers.length > 0) { %>
                            <% pendingTeachers.forEach(teacher => { %>
                                <tr>
                                    <td><%= teacher.nome %></td>
                                    <td><%= teacher.email %></td>
                                    <td><%= new Date(teacher.criado_em).toLocaleDateString('pt-BR') %></td>
                                    <td class="actions-buttons">
                                        <form action="/admin/teachers/<%= teacher.id %>/approve" method="POST" style="display: inline;">
                                            <button title="Aprovar" type="submit" class="btn btn-success"><i class="fa-solid fa-check"></i></button>
                                        </form>
                                        <form action="/admin/teachers/<%= teacher.id %>/reject" method="POST" style="display: inline;">
                                            <textarea name="reason" placeholder="Motivo..." required style="width: 100px; height: 30px; vertical-align: middle;"></textarea>
                                            <button title="Rejeitar" type="submit" class="btn btn-error"><i class="fa-solid fa-times"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4">Nenhum professor encontrado com os filtros atuais.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if(pagination.totalPages > 1) { %>
                <nav class="pagination">
                    <ul>
                        <% if(pagination.page > 1) { %>
                            <li><a href="/admin/dashboard?page=<%= pagination.page - 1 %>&status=<%= pagination.status %>&search=<%= pagination.search || '' %>#page-users">Anterior</a></li>
                        <% } %>

                        <% for(let i = 1; i <= pagination.totalPages; i++) { %>
                            <li class="<%= i === pagination.page ? 'active' : '' %>">
                                <a href="/admin/dashboard?page=<%= i %>&status=<%= pagination.status %>&search=<%= pagination.search || '' %>#page-users"><%= i %></a>
                            </li>
                        <% } %>

                        <% if(pagination.page < pagination.totalPages) { %>
                            <li><a href="/admin/dashboard?page=<%= pagination.page + 1 %>&status=<%= pagination.status %>&search=<%= pagination.search || '' %>#page-users">Próximo</a></li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>
        </section>

        <section class="card">
            <h2 class="section-title">Professores Ativos (<%= approvedTeachers.length %>)</h2>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Registrado em</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% approvedTeachers.forEach(teacher => { %>
                            <tr>
                                <td><%= teacher.nome %></td>
                                <td><%= teacher.email %></td>
                                <td><span class="status-badge status-<%= teacher.aprovacao_status %>"><%= teacher.aprovacao_status %></span></td>
                                <td><%= new Date(teacher.criado_em).toLocaleDateString('pt-BR') %></td>
                                <td class="actions-buttons">
                                    <form action="/admin/teachers/<%= teacher.id %>/suspend" method="POST" style="display: inline;">
                                        <textarea name="reason" placeholder="Motivo da suspensão..." required style="width: 100px; height: 30px; vertical-align: middle;"></textarea>
                                        <button title="Suspender" type="submit" class="btn btn-warning"><i class="fa-solid fa-ban"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </section>
        
        <section class="card">
            <h2 class="section-title">Professores Inativos e Suspensos (<%= inactiveTeachers.length %>)</h2>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Registrado em</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% inactiveTeachers.forEach(teacher => { %>
                            <tr>
                                <td><%= teacher.nome %></td>
                                <td><%= teacher.email %></td>
                                <td><span class="status-badge status-<%= teacher.aprovacao_status %>"><%= teacher.aprovacao_status %></span></td>
                                <td><%= new Date(teacher.criado_em).toLocaleDateString('pt-BR') %></td>
                                <td class="actions-buttons">
                                     <form action="/admin/teachers/<%= teacher.id %>/reactivate" method="POST" style="display: inline;">
                                        <button title="Reativar" type="submit" class="btn btn-primary"><i class="fa-solid fa-redo"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </section>

    </section>

    <!-- FINANCEIRO -->
    <section class="content-page" id="page-finance">
      <section class="card">
        <h2 class="section-title">Repasses Pendentes</h2>
        <section class="table-wrapper"><table class="data-table"></table></section>
      </section>
      <section class="card">
        <h2 class="section-title">Extrato de Transações</h2>
        <section class="table-wrapper"><table class="data-table"></table></section>
      </section>
    </section>

    <!-- MODERAÇÃO -->
    <section class="content-page" id="page-moderation">
      <section class="card">
        <h2 class="section-title">Denúncias Recebidas (<%= (denuncias || []).length %>)</h2>
        <section class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Tipo</th>
                <th>Título</th>
                <th>Prioridade</th>
                <th>Status</th>
                <th>Contato</th>
                <th>Enviada em</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (denuncias && denuncias.length > 0) { %>
                <% denuncias.forEach(denuncia => { %>
                  <tr>
                    <td>#<%= denuncia.id %></td>
                    <td><%= denuncia.tipo %></td>
                    <td>
                      <strong><%= denuncia.titulo %></strong><br>
                      <small><%= denuncia.descricao && denuncia.descricao.length > 120 ? denuncia.descricao.slice(0, 120) + '...' : denuncia.descricao %></small>
                      <% if (denuncia.evidencia) { %><br><a href="<%= denuncia.evidencia %>" target="_blank" rel="noopener">Ver evidência</a><% } %>
                    </td>
                    <td><span class="status-badge status-<%= denuncia.prioridade %>"><%= denuncia.prioridade %></span></td>
                    <td><span class="status-badge status-<%= denuncia.status %>"><%= denuncia.status %></span></td>
                    <td><%= denuncia.anonimo ? 'Anônimo' : (denuncia.email || 'Não informado') %></td>
                    <td><%= new Date(denuncia.criado_em).toLocaleString('pt-BR') %></td>
                    <td class="actions-buttons">
                      <form action="/admin/denuncias/<%= denuncia.id %>/status" method="POST" style="display:inline-flex; gap: 6px; align-items:center;">
                        <select name="status" aria-label="Status da denúncia <%= denuncia.id %>">
                          <option value="aberta" <%= denuncia.status === 'aberta' ? 'selected' : '' %>>Aberta</option>
                          <option value="em_analise" <%= denuncia.status === 'em_analise' ? 'selected' : '' %>>Em análise</option>
                          <option value="resolvida" <%= denuncia.status === 'resolvida' ? 'selected' : '' %>>Resolvida</option>
                        </select>
                        <button type="submit" class="btn btn-primary">Salvar</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="8">Nenhuma denúncia recebida.</td></tr>
              <% } %>
            </tbody>
          </table>
        </section>
      </section>
    </section>

    <!-- CONFIGURAÇÕES -->
    <section class="content-page" id="page-settings">
      <section class="card">
        <h2 class="section-title">Configurações da Plataforma</h2>
        <form id="settings-form">
          <section class="form-group">
            <label for="platform-fee">Taxa da Plataforma (%)</label>
            <input type="number" id="platform-fee" value="20" min="0" max="100" step="1">
            <small>Percentual que a Regimath retém sobre cada aula.</small>
          </section>
          <section class="form-group">
            <label for="admin-email">E-mail de Suporte</label>
            <input type="email" id="admin-email" value="contato@regimath.com">
          </section>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> Salvar</button>
        </form>
      </section>
    </section>
  </main>

  <!-- Scripts -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const menuBtn = document.getElementById('menu-btn');
      const menu = document.getElementById('menu');
      const overlay = document.getElementById('overlay');
      const closeBtn = document.getElementById('close-menu');
      const toggleBtn = document.getElementById('toggle-menu');
      const toggleIcon = document.getElementById('toggle-icon');
      const navLinks = document.querySelectorAll('.admin-nav-link');
      const pages = document.querySelectorAll('.content-page');
      const pageTitle = document.getElementById('page-title');

      // === Menu Mobile (Existing Code) ===
      const toggleMobileMenu = () => {
        menu.classList.toggle('active');
        overlay.classList.toggle('active');
        document.body.classList.toggle('no-scroll', menu.classList.contains('active'));
      };
      [menuBtn, overlay, closeBtn].forEach(el => el?.addEventListener('click', toggleMobileMenu));

      // === Collapsible Menu (Existing Code) ===
      if (toggleBtn) {
        const isCollapsed = localStorage.getItem('adminMenuCollapsed') === 'true';
        if (isCollapsed) {
          menu.classList.add('collapsed');
          toggleIcon.style.transform = 'rotate(180deg)';
        }
        toggleBtn.addEventListener('click', () => {
          menu.classList.toggle('collapsed');
          const collapsed = menu.classList.contains('collapsed');
          toggleIcon.style.transform = collapsed ? 'rotate(180deg)' : 'rotate(0deg)';
          localStorage.setItem('adminMenuCollapsed', collapsed);
        });
      }

      // === Page Switching (Existing Code) ===
      const showPage = (targetId) => {
        pages.forEach(p => p.classList.toggle('active', p.id === targetId.substring(1)));
        navLinks.forEach(l => {
          const active = l.getAttribute('href') === targetId;
          l.classList.toggle('active', active);
          if (active && pageTitle) pageTitle.textContent = l.querySelector('.label').textContent;
        });
        // This check prevents the URL hash from being cleared on initial load
        if (window.location.hash !== targetId) {
            window.history.pushState(null, '', targetId);
        }
      };

      navLinks.forEach(link => {
        link.addEventListener('click', e => {
          const target = link.getAttribute('href');
          if (target.startsWith('/')) return;
          e.preventDefault();
          showPage(target);
          if (window.innerWidth < 768) toggleMobileMenu();
        });
      });

      // === Fetch and Display Real-Time KPIs ===
      const formatCurrency = (value) => {
          return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value);
      };

      const fetchDashboardData = async () => {
          try {
              const response = await fetch('/admin/dashboard/summary');
              if (!response.ok) throw new Error('Failed to load dashboard data');
              const data = await response.json();

              document.getElementById('kpi-revenue').textContent = formatCurrency(data.monthlyRevenue);
              document.getElementById('kpi-pending-payments').textContent = formatCurrency(data.pendingPayments);
              document.getElementById('kpi-new-students').textContent = data.newStudents;
              document.getElementById('kpi-completed-classes').textContent = data.completedClasses;
              document.getElementById('kpi-open-reports').textContent = data.openReports;
              
              const openReportsBadge = document.getElementById('open-reports-badge');
              if(openReportsBadge) openReportsBadge.textContent = data.openReports;

          } catch (error) {
              console.error('Error updating KPIs:', error);
              document.querySelectorAll('.kpi-value').forEach(el => el.textContent = "Erro");
          }
      };

      // Load initial page and data
      const currentHash = window.location.hash || '#page-dashboard';
      // Ensure the correct page is shown on load, especially after form submission
      if (currentHash && document.querySelector(currentHash)) {
          showPage(currentHash);
      } else {
          showPage('#page-dashboard');
      }
      fetchDashboardData();
    });
  </script>
</body>
</html>
