<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meu Progresso</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bordo: #800020;
      --bordo-escuro: #520d23;
      --bordo-claro: #a83244;
      --dourado: #f4c542;
      --verde: #16a34a;
      --vermelho: #dc2626;
      --texto: #1f2937;
      --texto-claro: #6b7280;
      --fundo: #f6f8fb;
      --card: rgba(255, 255, 255, 0.92);
      --borda: rgba(128, 0, 32, 0.08);
      --sombra: 0 12px 30px rgba(15, 23, 42, 0.10);
      --sombra-hover: 0 18px 40px rgba(15, 23, 42, 0.14);
      --raio: 18px;
      --raio-sm: 12px;
      --transicao: 0.25s ease;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Poppins", sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
      color: var(--texto);
      line-height: 1.6;
    }
    body.no-scroll {
    overflow: hidden;
}

/* =======================
        LAYOUT
======================= */
main {
  max-width: 1200px;
  margin: 2rem auto;
  padding: 1rem;
}

header {
  background: #fff;
  box-shadow: var(--sombra);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 20px; /* Padding ajustado */
  position: sticky;
  top: 0;
  margin-left: -20px;
  z-index: 100;
  border-bottom: 2px solid var(--bordo);
  height: 60px;
}

.logo {
  margin-top: 10px;
  margin-left: -15px;
  width: 120px;
  height: 70px;
  object-fit: contain;
}

.menu-btn {
  font-size: 1.8rem;
  background: none;
  border: none;
  color: #800020;
  cursor: pointer;
}

/* ============ MENU LATERAL ============ */
nav {
  position: fixed;
  top: 0;
  left: -260px; /* Largura base aumentada para 260px */
  width: 260px;
  height: 100vh;
  background: #800020;
  padding-top: 60px; /* Espaço para o header */
  transition: 0.3s;
  z-index: 1002;
}

nav.active {
  left: 0px;
}

.nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
}

.nav-links li {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

nav a {
  color: #fff;
  text-decoration: none;
  padding: 8px 24px;
  font-size: 1rem;
  transition: background 0.3s;
  display: block;
}

nav a:hover {
  background: #b22222;
}

#close-menu {
  position: absolute;
  top: 10px;
  right: 15px;
  background: none;
  border: none;
  font-size: 2rem;
  color: #fff;
  cursor: pointer;
}

/* Botão de recolher (desktop) */
#toggle-menu {
  position: absolute;
  top: 15px;
  right: -17px; /* Posicionado fora do painel */
  width: 42px;
  height: 42px;
  border-radius: 8px;
  background: #800020;
  border: 2px solid rgba(255,255,255,0.2);
  display: none; 
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 1003;
  box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}

#toggle-menu:hover { transform: scale(1.05); }

#toggle-menu svg { transform-origin: center; transition: transform 0.3s ease; }

/* Overlay */
#overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  opacity: 0;
  visibility: hidden;
  transition: 0.3s;
  z-index: 1001;
}

#overlay.active {
  opacity: 1;
  visibility: visible;
}

svg {
  object-fit: contain;
  width: 24px;
  height: 24px;
  stroke: #fff;
}

    .hero {
      background: linear-gradient(135deg, var(--bordo) 0%, var(--bordo-claro) 100%);
      color: white;
      border-radius: var(--raio);
      box-shadow: var(--sombra);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top right, rgba(255,255,255,0.12), transparent 35%);
      pointer-events: none;
    }

    .hero h1 {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 800;
      margin-bottom: 0.5rem;
    }

    .hero p {
      font-size: 0.98rem;
      max-width: 700px;
      opacity: 0.95;
      margin: 0;
    }

    .card {
      border: 1px solid var(--borda);
      border-radius: var(--raio);
      background: var(--card);
      box-shadow: var(--sombra);
      transition: transform var(--transicao), box-shadow var(--transicao);
      overflow: hidden;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: var(--sombra-hover);
    }

    .card-body {
      padding: 1.25rem;
    }

    .card-title {
      font-weight: 700;
      color: var(--bordo);
      margin-bottom: 1rem;
      font-size: 1.05rem;
    }

    .info-box {
      background: linear-gradient(180deg, #fff, #fafafa);
      border: 1px solid rgba(128, 0, 32, 0.08);
      border-radius: var(--raio-sm);
      padding: 1rem;
      margin-bottom: 1rem;
    }

    .progress-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
      font-size: 0.92rem;
      color: var(--texto-claro);
    }

    .progress-label strong {
      color: var(--texto);
      font-size: 1rem;
    }

    .progress {
      height: 14px;
      border-radius: 999px;
      background: #e5e7eb;
      overflow: hidden;
    }

    .progress-bar {
      background: linear-gradient(90deg, var(--bordo), var(--bordo-claro), var(--dourado));
      font-weight: 700;
      font-size: 0.75rem;
      color: white;
      text-align: center;
      transition: width 0.6s ease;
    }

    .xp-text {
      margin-top: 0.65rem;
      font-size: 0.9rem;
      color: var(--texto-claro);
    }

    .streak-box {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      background: linear-gradient(135deg, rgba(255, 243, 205, 0.5), rgba(255, 255, 255, 0.95));
      border: 1px solid rgba(244, 197, 66, 0.25);
      border-radius: var(--raio-sm);
      padding: 1rem;
    }

    .streak-emoji {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(244, 197, 66, 0.18);
      font-size: 1.4rem;
      flex: 0 0 auto;
    }

    .streak-box p {
      margin: 0;
    }

    .streak-box strong {
      color: var(--bordo);
    }

    .skills-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: var(--raio);
      box-shadow: var(--sombra);
    }

    .skills-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .skill-column {
      background: linear-gradient(180deg, #fff, #fcfcfd);
      border: 1px solid rgba(128, 0, 32, 0.08);
      border-radius: var(--raio-sm);
      padding: 1rem;
    }

    .skill-column h6 {
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.45rem;
    }

    .skill-column.strong h6 {
      color: var(--verde);
    }

    .skill-column.weak h6 {
      color: var(--vermelho);
    }

    .skill-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.65rem;
    }

    .skill-item {
      padding: 0.8rem 0.9rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.92rem;
      background: #f8fafc;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .skill-item strong {
      font-weight: 600;
    }

    .skill-item.strong {
      color: var(--verde);
      border-left: 4px solid var(--verde);
    }

    .skill-item.weak {
      color: var(--vermelho);
      border-left: 4px solid var(--vermelho);
    }

    .empty-state {
      padding: 1rem;
      border-radius: 12px;
      background: #f8fafc;
      color: var(--texto-claro);
      font-size: 0.92rem;
      text-align: center;
      border: 1px dashed rgba(128, 0, 32, 0.15);
    }

    footer {
      color: var(--texto-claro);
      font-size: 0.9rem;
    }

    @media (min-width: 768px) {
      .menu-btn,
  #overlay,
  #close-menu {
    display: none;
  }

  #toggle-menu { display: flex; }

  nav {
    left: 0;
    width: 260px;
    border-right: 2px solid var(--bordo);
    padding-top: 0;
  }

  main {
    margin-left: 260px;
    transition: margin-left 0.3s ease;
    position: sticky;
    left: 25%;
  }

  nav.collapsed {
    width: 70px;
  }

  nav.collapsed ~ main {
    margin-left: 70px;
  }

  nav.collapsed a {
    text-indent: -9999px;
    white-space: nowrap;
    overflow: hidden;
    display: none;
  }

  nav.collapsed .nav-links li {
    line-height: 42px;
    overflow: hidden;
    display: none;
  }

  nav.collapsed a {
    padding-left: 0;
    padding-right: 0;
    text-align: center;
  }

  .logo {
    position: absolute;
    top: -10px;
    left: 265px;
    width: 175px;
  }

      .hero {
        padding: 2rem;
        margin-bottom: 2rem;
      }

      .card-body {
        padding: 1.5rem;
      }

      .skills-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .streak-box {
        padding: 1.1rem 1.2rem;
      }
    }

    @media (min-width: 1024px) {
      main{
    padding: 2rem -50rem;
    width: 1000px;
    position: sticky;
    left: 18%;
  }

      .hero {
        padding: 2.3rem;
      }

      .card-body {
        padding: 1.7rem;
      }

      .skills-grid {
        gap: 1.2rem;
      }
    }
  </style>
</head>
<body>

  <header>
    <a href="/">
      <img src="/imagens/RM_bordo.png" alt="Regimath Logo" class="logo">
    </a>
    <button id="menu-btn" class="menu-btn" aria-label="Abrir menu principal">☰</button>
  </header>

  <section id="overlay"></section>

  <nav id="menu" class="overlay collapsed">

    <button id="close-menu" aria-label="Fechar menu">&times;</button>

    <button id="toggle-menu" aria-label="Recolher menu">
      <svg id="toggle-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="white">
        <path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z" />
      </svg>
    </button>

    <ul class="nav-links">
      <li><a href="/"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#fff"><path d="M264-216h96v-240h240v240h96v-348L480-726 264-564v348Zm-72 72v-456l288-216 288 216v456H528v-240h-96v240H192Zm288-327Z"/></svg>Home</a></li>

      <% if (session.user_aluno) { %>
          <li><a href="/perfil_aluno"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#fff"><path d="M234-276q51-39 114-61.5T480-360q69 0 132 22.5T726-276q35-41 54.5-93T800-480q0-133-93.5-226.5T480-800q-133 0-226.5 93.5T160-480q0 59 19.5 111t54.5 93Zm246-164q-59 0-99.5-40.5T340-580q0-59 40.5-99.5T480-720q59 0 99.5 40.5T620-580q0 59-40.5 99.5T480-440Zm0 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q53 0 100-15.5t86-44.5q-39-29-86-44.5T480-280q-53 0-100 15.5T294-220q39 29 86 44.5T480-160Zm0-360q26 0 43-17t17-43q0-26-17-43t-43-17q-26 0-43 17t-17 43q0 26 17 43t43 17Zm0-60Zm0 360Z"/></svg>Perfil aluno</a></li>
          <li><a href="/dashboard_aluno" class="pa"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#fff"><path d="M200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h560q33 0 56.5 23.5T840-760v560q0 33-23.5 56.5T760-120H200Zm0-80h240v-560H200v560Zm320 0h240v-280H520v280Zm0-360h240v-200H520v200Z"/></svg>Dashboard Aluno</a></li>
          <li><a href="/agenda" class="pa"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#fff"><path d="M216-96q-29.7 0-50.85-21.5Q144-139 144-168v-528q0-29 21.15-50.5T216-768h72v-96h72v96h240v-96h72v96h72q29.7 0 50.85 21.5Q816-725 816-696v528q0 29-21.15 50.5T744-96H216Zm0-72h528v-360H216v360Zm0-432h528v-96H216v96Zm0 0v-96 96Zm264.21 216q-15.21 0-25.71-10.29t-10.5-25.5q0-15.21 10.29-25.71t25.5-10.5q15.21 0 25.71 10.29t10.5 25.5q0 15.21-10.29 25.71t-25.5 10.5Zm-156 0q-15.21 0-25.71-10.29t-10.5-25.5q0-15.21 10.29-25.71t25.5-10.5q15.21 0 25.71 10.29t10.5 25.5q0 15.21-10.29 25.71t-25.5 10.5Zm312 0q-15.21 0-25.71-10.29t-10.5-25.5q0-15.21 10.29-25.71t25.5-10.5q15.21 0 25.71 10.29t10.5 25.5q0 15.21-10.29 25.71t-25.5 10.5Zm-156 144q-15.21 0-25.71-10.29t-10.5-25.5q0-15.21 10.29-25.71t25.5-10.5q15.21 0 25.71 10.29t10.5 25.5q0 15.21-10.29 25.71t-25.5 10.5Zm-156 0q-15.21 0-25.71-10.29t-10.5-25.5q0-15.21 10.29-25.71t25.5-10.5q15.21 0 25.71 10.29t10.5 25.5q0 15.21-10.29 25.71t-25.5 10.5Zm312 0q-15.21 0-25.71-10.29t-10.5-25.5q0-15.21 10.29-25.71t25.5-10.5q15.21 0 25.71 10.29t10.5 25.5q0 15.21-10.29 25.71t-25.5 10.5Z"/></svg>Agenda</a></li>
          <li><a href="/historico_chats" class="pa"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#fff"><path d="M240-400h320v-80H240v80Zm0-120h480v-80H240v80Zm0-120h480v-80H240v80ZM80-80v-720q0-33 23.5-56.5T160-880h640q33 0 56.5 23.5T880-800v480q0 33-23.5 56.5T800-240H240L80-80Zm126-240h594v-480H160v525l46-45Zm-46 0v-480 480Z"/></svg>Histórico de Chats</a></li>
          <li><a href="/logout"><svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#fff"><path d="M216-144q-29.7 0-50.85-21.15Q144-186.3 144-216v-528q0-29.7 21.15-50.85Q186.3-816 216-816h264v72H216v528h264v72H216Zm432-168-51-51 81-81H384v-72h294l-81-81 51-51 168 168-168 168Z"/></svg>Sair</a></li>
      <% } %>
    </ul>
  </nav>

  <main class="container">
    <section class="hero">
      <h1>Meu Progresso</h1>
      <p>Acompanhe sua evolução, seus pontos fortes e as áreas para focar seus estudos.</p>
    </section>

    <div class="row">
      <div class="col-lg-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title">Nível e Experiência</h5>

            <div class="info-box">
              <div class="progress-label">
                <span>Nível atual</span>
                <strong><%= dashboard.aluno.nivel %></strong>
              </div>

              <div class="progress">
                <div
                  class="progress-bar"
                  role="progressbar"
                  style="width: <%= dashboard.progressoNivel.percentual %>%"
                  aria-valuenow="<%= dashboard.progressoNivel.percentual %>"
                  aria-valuemin="0"
                  aria-valuemax="100">
                  <%= dashboard.progressoNivel.percentual %>%
                </div>
              </div>

              <div class="xp-text">
                <%= dashboard.progressoNivel.xpAtual %> / <%= dashboard.progressoNivel.xpProximoNivel %> XP para o próximo nível
              </div>
            </div>

            <div class="streak-box">
              <div class="streak-emoji"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#800020"><path d="M240-400q0 52 21 98.5t60 81.5q-1-5-1-9v-9q0-32 12-60t35-51l113-111 113 111q23 23 35 51t12 60v9q0 4-1 9 39-35 60-81.5t21-98.5q0-50-18.5-94.5T648-574q-20 13-42 19.5t-45 6.5q-62 0-107.5-41T401-690q-39 33-69 68.5t-50.5 72Q261-513 250.5-475T240-400Zm240 52-57 56q-11 11-17 25t-6 29q0 32 23.5 55t56.5 23q33 0 56.5-23t23.5-55q0-16-6-29.5T537-292l-57-56Zm0-492v132q0 34 23.5 57t57.5 23q18 0 33.5-7.5T622-658l18-22q74 42 117 117t43 163q0 134-93 227T480-80q-134 0-227-93t-93-227q0-129 86.5-245T480-840Z"/></svg></div>
              <div>
                <p><strong>Streak de estudo:</strong> <%= dashboard.aluno.streak %> dias</p>
                <small class="text-muted">Continue estudando todos os dias para não perder sua sequência!</small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-8 mb-4">
        <div class="card skills-card">
          <div class="card-body">
            <h5 class="card-title">Resumo de Habilidades</h5>

            <div class="skills-grid">
              <div class="skill-column strong">
                <h6><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#90EE90"><path d="M382-240 154-468l57-57 171 171 367-367 57 57-424 424Z"/></svg> Pontos Fortes</h6>

                <% if (dashboard.resumoHabilidades.pontosFortes.length > 0) { %>
                  <ul class="skill-list">
                    <% dashboard.resumoHabilidades.pontosFortes.forEach(h => { %>
                      <li class="skill-item strong">
                        <span><%= h.habilidade %></span>
                      </li>
                    <% }); %>
                  </ul>
                <% } else { %>
                  <div class="empty-state">
                    Continue praticando para descobrirmos seus pontos fortes!
                  </div>
                <% } %>
              </div>

              <div class="skill-column weak">
                <h6><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#f08080"><path d="m40-120 440-760 440 760H40Zm138-80h604L480-720 178-200Zm330.5-51.5Q520-263 520-280t-11.5-28.5Q497-320 480-320t-28.5 11.5Q440-297 440-280t11.5 28.5Q463-240 480-240t28.5-11.5ZM440-360h80v-200h-80v200Zm40-100Z"/></svg> Pontos a Melhorar</h6>

                <% if (dashboard.resumoHabilidades.pontosAMelhorar.length > 0) { %>
                  <ul class="skill-list">
                    <% dashboard.resumoHabilidades.pontosAMelhorar.forEach(h => { %>
                      <li class="skill-item weak">
                        <span><%= h.habilidade %></span>
                      </li>
                    <% }); %>
                  </ul>
                <% } else { %>
                  <div class="empty-state">
                    Nenhum ponto de melhoria específico no momento. Ótimo trabalho!
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('menu-btn');
    const menu = document.getElementById('menu');
    const overlay = document.getElementById('overlay');
    const closeBtn = document.getElementById('close-menu');
    const toggleBtn = document.getElementById("toggle-menu");

    function toggleMobileMenu() {
      menu.classList.toggle('active');
      overlay.classList.toggle('active');
      document.body.classList.toggle('no-scroll', menu.classList.contains('active'));
    }

    if (menuBtn) menuBtn.addEventListener('click', toggleMobileMenu);
    if (overlay) overlay.addEventListener('click', toggleMobileMenu);
    if (closeBtn) closeBtn.addEventListener('click', toggleMobileMenu);

    if (toggleBtn) {
      const toggleIcon = document.getElementById('toggle-icon');
      const isCollapsed = menu.classList.contains('collapsed');
      toggleBtn.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
      if (isCollapsed) toggleIcon.style.transform = 'rotate(180deg)';

      toggleBtn.addEventListener("click", (e) => {
        e.preventDefault();
        menu.classList.toggle("collapsed");
        const isNowCollapsed = menu.classList.contains('collapsed');
        toggleBtn.setAttribute('aria-expanded', isNowCollapsed ? 'false' : 'true');
        toggleIcon.style.transform = isNowCollapsed ? 'rotate(180deg)' : 'rotate(0deg)';
      });
    }});
  </script>
</body>
</html>