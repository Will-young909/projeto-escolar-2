<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Missão Cumprida! | Regimath</title>
    
    <!-- Bootstrap 5 & FontAwesome -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-grad: linear-gradient(135deg, #800000 0%, #800020 100%);
            --bg-color: #f0f2f5;
        }

        body {
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(at 0% 0%, rgba(138, 43, 226, 0.05) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(40, 167, 69, 0.05) 0px, transparent 50%);
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }

        .card-celebracao {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            padding: 50px 40px;
            text-align: center;
            max-width: 550px;
            width: 90%;
            animation: appear 0.8s cubic-bezier(0.17, 0.67, 0.83, 0.67) forwards;
            opacity: 0;
        }

        @keyframes appear {
            from { transform: scale(0.9) translateY(30px); opacity: 0; }
            to { transform: scale(1) translateY(0); opacity: 1; }
        }

        .icon-box {
            font-size: 80px;
            margin-bottom: 20px;
            display: inline-block;
            background: var(--primary-grad);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        h1 {
            font-weight: 800;
            color: #2d3436;
            margin-bottom: 15px;
            font-size: 2.5rem;
        }

        p {
            color: #636e72;
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .btn-principal {
            background: var(--primary-grad);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(138, 43, 226, 0.2);
            text-decoration: none;
            display: inline-block;
        }

        .btn-principal:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 25px rgba(138, 43, 226, 0.3);
            color: white;
            filter: brightness(1.1);
        }
    </style>
</head>
<body>

    <div class="card-celebracao">
        <div class="icon-box">
            <i class="fas fa-trophy"></i>
        </div>
        
        <h1>Parabéns!</h1>
        <p>Você concluiu sua trilha de reforço com sucesso. Seu empenho está dando resultados incríveis!</p>
        
        <a href="/dashboard_aluno" class="btn-principal">
            <i class="fas fa-arrow-left me-2"></i> Voltar ao Painel
        </a>
    </div>

    <!-- Script de Confetes -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script>
        // Dispara os confetes automaticamente ao carregar
        window.onload = function() {
            var duration = 3 * 1000;
            var end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 3,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0 },
                    colors: ['#8A2BE2', '#4CAF50', '#FFD700']
                });
                confetti({
                    particleCount: 3,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1 },
                    colors: ['#8A2BE2', '#4CAF50', '#FFD700']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());
        };
    </script>
</body>
</html>